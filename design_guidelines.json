    "icons": {
      "library": "lucide-react",
      "style": "Stroke width 1.5px (Thin/Elegant)"
    }
  },
  "motion": {
    "reduced_motion": "respect-preference",
    "transitions": "transition-all duration-200 ease-in-out",
    "hover_effects": "scale-[1.01] brightness-110",
    "page_transition": "opacity-0 to opacity-100 duration-300"
  },
  "accessibility": {
    "contrast": "WCAG AA compliant",
    "focus_ring": "ring-2 ring-primary ring-offset-2 ring-offset-background",
    "aria_labels": "Mandatory for all icon-only buttons"
  },
  "instructions_to_main_agent": [
    "Use 'lucide-react' for all icons.",
    "Implement a 'Sidebar' layout with a collapsible trigger.",
    "Use 'Recharts' for all financial charts (Line, Pie, Bar).",
    "Ensure all dates are formatted in French (DD/MM/YYYY).",
    "Use 'Sonner' for toast notifications.",
    "For the 'Matrix' view, use a custom grid layout with filtering.",
    "Implement 'Lazy Loading' for images in the inventory to support NAS performance.",
    "Use 'data-testid' on all interactive elements.",
    "Do NOT use gradients for backgrounds, use solid colors or subtle noise textures.",
    "Keep the interface in French as requested."
  ],
  "universal_guidelines": [
    "Avoid 'AI slop' aesthetic (generic centered layouts).",
    "Create depth through layered design elements with z-index hierarchy.",
    "Use glass-morphism effects with backdrop filters (12-24px blur) for overlays.",
    "Every interaction needs micro-animations.",
    "Use 2-3x more spacing than feels comfortable in content pages, but keep dashboards dense.",
    "Subtle grain textures and noise overlays are encouraged."
  ]
}